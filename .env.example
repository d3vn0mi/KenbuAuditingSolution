# Flask
FLASK_CONFIG=production
SECRET_KEY=change-me-to-a-random-string

# Database (PostgreSQL)
DATABASE_URL=postgresql://kenbu:CHANGE_ME@db:5432/kenbu
POSTGRES_USER=kenbu
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=kenbu

# GitHub OAuth SSO (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Evidence encryption at rest (REQUIRED in production). Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EVIDENCE_ENCRYPTION_KEY=
# Optional: comma-separated older keys to allow decryption during key rotation.
EVIDENCE_ENCRYPTION_KEYS_OLD=
